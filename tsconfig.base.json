{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2023",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "react",
      "react-dom"
    ],
    "baseUrl": ".",
    "paths": {
      "@flowlab/auth": [
        "packages/auth/src"
      ],
      "@flowlab/automation": [
        "packages/automation/src"
      ],
      "@flowlab/branding": [
        "packages/branding/src"
      ],
      "@flowlab/contracts": [
        "packages/contracts/src"
      ],
      "@flowlab/db": [
        "packages/db/src"
      ],
      "@flowlab/events": [
        "packages/events/src"
      ],
      "@flowlab/integrations": [
        "packages/integrations/src"
      ],
      "@flowlab/ui": [
        "packages/ui/src"
      ]
    }
  }
}
