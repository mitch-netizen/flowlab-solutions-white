generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TenantStatus {
  trial
  active
  suspended
  cancelled
}

enum TenantPlan {
  starter
  professional
  growth
}

enum BusinessType {
  plumbing
  electrical
  hvac
  roofing
  painting
  carpentry
  glazing
  locksmith
  garage_doors
  lawn_mowing
  gardening
  landscaping
  pool_service
  pressure_washing
  gutter_cleaning
  tree_services
  fencing
  residential_cleaning
  commercial_cleaning
  bond_cleaning
  pest_control
  carpet_cleaning
  window_cleaning
  fire_safety
  test_and_tag
  mobile_mechanic
  appliance_repair
  solar
  security_systems
  cleaning
  handyman
  other
}

enum IntegrationManagementMode {
  platform_managed
  tenant_managed
  connected_account
  advanced_optional
}

enum IntegrationService {
  twilio
  sendgrid
  stripe
  docuseal
  google_maps
  xero
  make_com
  claude
}

enum IntegrationStatus {
  not_configured
  connected
  error
  disconnected
}

enum EventType {
  api_call
  webhook_fired
  webhook_received
  error
  warning
  info
}

enum EventDirection {
  outbound
  inbound
}

enum EventStatus {
  success
  failed
  pending
  timeout
}

enum AutomationJobStatus {
  pending
  processing
  completed
  failed
  dead_letter
}

enum UserRole {
  superadmin
  support
  billing
  owner
  staff
}

enum JobStatus {
  quoted
  scheduled
  in_progress
  complete
  invoiced
  paid
}

model Tenant {
  id                    String              @id @default(uuid())
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  slug                  String              @unique
  status                TenantStatus
  plan                  TenantPlan
  trialEndsAt           DateTime?
  billingEmail          String
  subscriptionStartDate DateTime?
  monthlyFee            Float
  stripeCustomerId      String?
  stripeSubscriptionId     String? @unique
  stripeSubscriptionStatus String?
  stripePriceId            String?
  notes                 String?
  profile               TenantProfile?
  integrations          TenantIntegration[]
  users                 TenantUser[]
  customers             Customer[]
  enquiries             Enquiry[]
  services              Service[]
  jobs                  Job[]
  quotes                Quote[]
  agreements            Agreement[]
  agreementTemplates    TenantAgreementTemplate[]
  invoices              Invoice[]
  communications        Communication[]
  feedback              Feedback[]
  rebookReminders       RebookReminder[]
  pricingRates          PricingRate[]
  serviceRateTemplates  ServiceRateTemplate[]
  timeEstimateHistory   TimeEstimateHistory[]
  workSchedule          WorkSchedule[]
  timeOff               TimeOff[]
  personalCommitments   PersonalCommitment[]
  events                PlatformEventLog[]
  usageEvents           TenantUsageEvent[]
  actionSuggestions     ActionSuggestion[]
  apiKeys               TenantApiKey[]
  automationJobs        AutomationJob[]
  automationPreferences AutomationPreference[]
  supportThreads        SupportThread[]
}

model TenantProfile {
  id                   String       @id @default(uuid())
  tenantId             String       @unique
  businessName         String
  tagline              String?
  logoUrl              String?
  faviconUrl           String?
  primaryColour        String
  secondaryColour      String
  accentColour         String
  fontPreference       String?
  customDomain         String?      @unique
  customDomainVerified Boolean      @default(false)
  abn                  String?
  phone                String?
  email                String?
  address              String?
  suburb               String?
  state                String?
  postcode             String?
  serviceAreaSuburbs   String[]
  serviceBaseAddress   String?
  serviceBasePlaceId   String?
  serviceBaseLat       Float?
  serviceBaseLng       Float?
  serviceRadiusKm      Float?
  businessType                BusinessType
  timezone                    String       @default("Australia/Brisbane")
  emailSignatureEnabled       Boolean      @default(true)
  emailSignatureAdHocDefault  Boolean      @default(true)
  emailSignatureCustomHtml    String?
  tenant                      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([customDomain])
}

model TenantIntegration {
  id                String            @id @default(uuid())
  tenantId          String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  service           IntegrationService
  status            IntegrationStatus @default(not_configured)
  credentialsJson   String?
  managementMode    IntegrationManagementMode @default(tenant_managed)
  lastTestedAt      DateTime?
  lastTestResult    String?
  lastErrorMessage  String?
  webhookUrl        String?
  oauthAccessToken  String?
  oauthRefreshToken String?
  oauthExpiresAt    DateTime?
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, service])
}

model PlatformIntegration {
  id                String            @id @default(uuid())
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  service           IntegrationService @unique
  status            IntegrationStatus @default(not_configured)
  credentialsJson   String?
  lastTestedAt      DateTime?
  lastTestResult    String?
  lastErrorMessage  String?
  webhookUrl        String?
  oauthAccessToken  String?
  oauthRefreshToken String?
  oauthExpiresAt    DateTime?
}

model TenantUsageEvent {
  id          String   @id @default(uuid())
  tenantId    String
  createdAt   DateTime @default(now())
  service     String
  operation   String
  quantity    Int      @default(1)
  metadataJson String?
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, service, createdAt])
}

model ActionSuggestion {
  id              String   @id @default(uuid())
  tenantId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  category        String
  priority        String
  title           String
  reason          String
  targetUrl       String
  suggestedAction String
  status          String   @default("open")
  snoozedUntil    DateTime?
  source          String
  sourceId        String?
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, createdAt])
  @@index([tenantId, category, createdAt])
}

model PlatformEventLog {
  id              String         @id @default(uuid())
  createdAt       DateTime       @default(now())
  tenantId        String?
  eventType       EventType
  service         String
  direction       EventDirection
  status          EventStatus
  httpStatusCode  Int?
  requestSummary  String?
  responseSummary String?
  durationMs      Int?
  errorMessage    String?
  jobId           String?
  customerId      String?
  triggeredBy     String?
  reviewedAt      DateTime?
  tenant          Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
}

model PlatformUser {
  id           String    @id @default(uuid())
  authUserId   String?   @unique
  email        String    @unique
  passwordHash String?
  role         UserRole
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?
}

model TenantUser {
  id                  String    @id @default(uuid())
  tenantId            String
  authUserId          String?   @unique
  email               String
  passwordHash        String?
  role                UserRole
  firstName           String
  lastName            String
  createdAt           DateTime  @default(now())
  lastLoginAt         DateTime?
  onboardingCompleted Boolean   @default(false)
  onboardingStep      Int       @default(1)
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
}

model Customer {
  id             String           @id @default(uuid())
  tenantId       String
  createdAt      DateTime         @default(now())
  firstName      String
  lastName       String
  email          String
  phone          String?
  address        String?
  suburb         String?
  notes          String?
  ratingAverage  Float?
  xeroContactId  String?          // Xero Contact ID — set when first synced to Xero
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enquiries      Enquiry[]
  jobs           Job[]
  quotes         Quote[]
  agreements     Agreement[]
  invoices       Invoice[]
  communications Communication[]

  @@index([tenantId])
}

model Enquiry {
  id             String    @id @default(uuid())
  tenantId       String
  customerId     String
  quoteId        String?   @unique
  createdAt      DateTime  @default(now())
  serviceRequest String
  status         String    @default("new")
  source         String    @default("public_form")
  convertedAt    DateTime?
  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  quote          Quote?    @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
  @@index([customerId, createdAt])
}

model Service {
  id              String    @id @default(uuid())
  tenantId        String
  name            String
  description     String?
  defaultPrice    Float?
  defaultDuration Int?
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Job {
  id              String     @id @default(uuid())
  tenantId        String
  customerId      String
  serviceId       String?
  quoteId         String?    @unique
  createdAt       DateTime   @default(now())
  scheduledFor    DateTime?
  status          JobStatus
  address         String?
  suburb          String?
  summary         String
  estimatedHours  Float?
  actualHours     Float?
  weatherRisk     Boolean    @default(false)
  customer        Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quote           Quote?     @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  feedbacks       Feedback[]
  invoice         Invoice?
  communications  Communication[]

  @@index([tenantId])
  @@index([customerId])
}

model Quote {
  id             String    @id @default(uuid())
  tenantId       String
  customerId     String
  createdAt      DateTime  @default(now())
  title          String
  description    String?
  amount         Float
  status         String
  accessToken    String    @unique
  acceptedAt     DateTime?
  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  enquiry        Enquiry?
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job            Job?

  @@index([tenantId])
}

model Agreement {
  id             String    @id @default(uuid())
  tenantId       String
  customerId     String
  quoteId        String?
  contractTemplateId String?
  createdAt      DateTime  @default(now())
  title          String
  status         String
  accessToken    String    @unique
  signedAt       DateTime?
  externalId     String?
  signingUrl     String?
  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contractTemplate TenantAgreementTemplate? @relation(fields: [contractTemplateId], references: [id], onDelete: SetNull)
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TenantAgreementTemplate {
  id                  String      @id @default(uuid())
  tenantId            String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  name                String
  sourceFileName      String
  sourceMimeType      String?
  signerMode          String      @default("customer_only")
  signerRoles         String[]
  docusealTemplateId  String
  docusealTemplateSlug String?
  isDefault           Boolean     @default(false)
  status              String      @default("ready")
  lastSyncedAt        DateTime?
  lastErrorMessage    String?
  agreements          Agreement[]
  tenant              Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, docusealTemplateId])
  @@index([tenantId, isDefault])
}

model Invoice {
  id              String    @id @default(uuid())
  tenantId        String
  customerId      String
  jobId           String?   @unique
  createdAt       DateTime  @default(now())
  number          String
  amount          Float
  status          String
  dueAt           DateTime?
  paidAt          DateTime?
  paymentLink     String?
  stripeSessionId String?
  accessToken     String    @unique
  xeroInvoiceId   String?   // Xero Invoice ID — set when pushed to Xero; Xero is source of truth
  xeroStatus      String?   // Status as reported by Xero (DRAFT, SUBMITTED, AUTHORISED, PAID, VOIDED)
  xeroSyncedAt    DateTime? // Last time this invoice was synced from Xero
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  job             Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  communications  Communication[]

  @@unique([tenantId, number])
  @@index([customerId])
}

model Communication {
  id          String   @id @default(uuid())
  tenantId    String
  customerId  String?
  jobId       String?
  invoiceId   String?
  createdAt   DateTime @default(now())
  channel     String
  direction   String
  subject     String?
  body        String
  status      String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  job         Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  invoice     Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([tenantId, customerId, createdAt])
  @@index([tenantId, jobId, createdAt])
  @@index([tenantId, invoiceId, createdAt])
}

model Feedback {
  id          String   @id @default(uuid())
  tenantId    String
  customerId  String
  jobId       String?  @unique
  createdAt   DateTime @default(now())
  rating      Int
  comment     String?
  source      String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job         Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([customerId])
}

model RebookReminder {
  id          String   @id @default(uuid())
  tenantId    String
  customerId  String
  dueAt       DateTime
  sentAt      DateTime?
  status      String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, dueAt])
  @@index([customerId])
}

model PricingRate {
  id                   String   @id @default(uuid())
  tenantId             String
  label                String
  // Area-based model (lawn_mowing, gardening)
  baseRatePerSquareM   Float?
  overgrownRate        Float?
  heavilyOvergrownRate Float?
  // Hourly model (cleaning, handyman, pool_service)
  hourlyRate           Float?
  // Flat-rate model (plumbing, pest_control, other)
  calloutFee           Float?
  // Common fields
  minimumCharge        Float?
  gstEnabled           Boolean  @default(true)
  scheduleBufferPct    Float?   @default(10)
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ServiceRateTemplate {
  id              String   @id @default(uuid())
  tenantId        String
  serviceName     String
  defaultPrice    Float?
  defaultDuration Int?
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TimeEstimateHistory {
  id            String   @id @default(uuid())
  tenantId      String
  jobId         String?
  createdAt     DateTime @default(now())
  estimatedMins Int
  actualMins    Int
  variancePct   Float
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model WorkSchedule {
  id          String   @id @default(uuid())
  tenantId    String
  dayOfWeek   Int
  startTime   String
  endTime     String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TimeOff {
  id          String   @id @default(uuid())
  tenantId    String
  title       String
  startAt     DateTime
  endAt       DateTime
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model PersonalCommitment {
  id          String   @id @default(uuid())
  tenantId    String
  title       String
  address     String?
  notes       String?
  dayOfWeek   Int
  startTime   String
  endTime     String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TenantApiKey {
  id          String   @id @default(uuid())
  tenantId    String
  label       String
  hashedKey   String
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model AutomationJob {
  id           String              @id @default(uuid())
  tenantId     String?
  dedupeKey    String?             @unique
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  kind         String
  status       AutomationJobStatus @default(pending)
  payloadJson  String
  availableAt  DateTime            @default(now())
  processedAt  DateTime?
  attempts     Int                 @default(0)
  lastError    String?
  tenant       Tenant?             @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([status, availableAt])
  @@index([tenantId])
}

model AutomationPreference {
  id        String   @id @default(uuid())
  tenantId   String
  key       String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

model RateLimitBucket {
  id           String   @id @default(uuid())
  key          String   @unique
  scope        String
  count        Int      @default(0)
  windowStart  DateTime
  blockedUntil DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([scope, windowStart])
}

model SupportThread {
  id        String           @id @default(uuid())
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  tenantId  String
  subject   String
  status    String           @default("open")
  messages  SupportMessage[]
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([status, updatedAt])
}

model SupportMessage {
  id        String        @id @default(uuid())
  createdAt DateTime      @default(now())
  threadId  String
  body      String
  fromAdmin Boolean       @default(false)
  thread    SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}
