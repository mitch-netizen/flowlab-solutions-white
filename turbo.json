{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "dist/**"
      ],
      "outputMode": "hash-only"
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [],
      "outputMode": "hash-only"
    },
    "lint": {
      "outputs": [],
      "outputMode": "hash-only"
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  },
  "cacheDir": ".turbo"
}
