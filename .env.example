# DATABASE_URL must use Supabase's TRANSACTION pooler (port 6543) in production,
# not the session pooler (port 5432). Session mode caps at 15 connections and will
# exhaust under serverless load. Transaction mode scales to hundreds.
#
# Production format (get from Supabase → Settings → Database → Connection string → URI → Transaction):
#   DATABASE_URL="postgresql://postgres.xxxx:[password]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# DIRECT_URL stays on the direct / session connection — used only for migrations:
#   DIRECT_URL="postgresql://postgres.xxxx:[password]@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/flowlab"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/flowlab"
DEFAULT_ROOT_DOMAIN="flowlabsolutions.au"
JWT_SECRET="change-me"
ENCRYPTION_MASTER_KEY="change-me-change-me-change-me-change"
CRON_SECRET="change-me"

NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-public-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

TURNSTILE_SECRET_KEY=""
# Use Cloudflare's always-pass test key locally: 1x00000000000000000000AA
# Set to your real site key in Vercel env vars for production
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""
XERO_REDIRECT_URI="https://flowlabsolutions.au/api/integrations/xero/callback"
XERO_WEBHOOK_KEY=""

DOCUSEAL_API_KEY=""
DOCUSEAL_API_BASE_URL="https://api.docuseal.com"
DOCUSEAL_WEBHOOK_SECRET_KEY=""
DOCUSEAL_WEBHOOK_SECRET_VALUE=""
DOCUSEAL_APP_BASE_URL="https://docuseal.com"

BREVO_API_KEY=""
BREVO_SMS_SENDER=""
BREVO_SMS_ORGANISATION_PREFIX=""
BREVO_FROM_EMAIL=""
BREVO_FROM_NAME=""
BREVO_SANDBOX_MODE="false"

ANTHROPIC_API_KEY=""
GOOGLE_MAPS_API_KEY=""

STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
